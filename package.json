{
    "name":  "aht-launcher",
    "version":  "0.1.1",
    "private":  true,
    "type":  "module",
    "main":  "desktop/main.js",
    "desktopName":  "aht-launcher",
    "description":  "Private A Hard Time launcher and CurseForge-style updater.",
    "homepage":  "https://aht.local",
    "author":  {
                   "name":  "au Savant",
                   "email":  "launcher@aht.local"
               },
    "scripts":  {
                    "build-release":  "node src/cli.js build-release",
                    "install-pack":  "node src/cli.js install",
                    "serve-release":  "node src/cli.js serve-release",
                    "start":  "electron .",
                    "start:dev":  "electron . --developer",
                    "start:web":  "node src/web.js",
                    "test:platforms":  "node scripts/test-platform-profiles.mjs",
                    "test:platform-builds":  "node scripts/test-platform-build-configs.mjs",
                    "test:profile":  "node scripts/test-minecraft-profile.mjs",
                    "test:telemetry":  "node scripts/test-worker-telemetry.mjs",
                    "test:worker":  "node scripts/test-worker-release-hosting.mjs",
                    "test:player-defaults":  "node work/smoke-player-defaults-feed.mjs",
                    "test:settings-profile":  "node work/smoke-settings-profile-save.mjs",
                    "test:write-defaults":  "node work/smoke-write-player-defaults-button.mjs",
                    "test:developer-secret":  "node work/smoke-developer-secret-persistence.mjs",
                    "test:cloud-login":  "node work/smoke-cloud-login-required.mjs",
                    "test:cache-only-cloud":  "node work/smoke-cache-only-cloud-setup.mjs",
                    "test:launcher-self-update":  "node work/smoke-launcher-self-update.mjs",
                    "test:launcher-update-publish":  "node work/smoke-launcher-update-publish.mjs",
                    "test:launcher-update-manifest":  "node scripts/test-launcher-update-manifest.mjs",
                    "test:server-transfer-plan":  "node work/smoke-server-transfer-plan.mjs",
                    "test:mod-only-changes":  "node work/smoke-mod-only-changes.mjs",
                    "test:play-gate":  "node work/smoke-play-integrity-gate.mjs",
                    "test:account-duplicate":  "node work/smoke-account-duplicate-ui.mjs",
                    "test:cache-fallback":  "node work/smoke-cache-fallback-install.mjs",
                    "test:update-logs":  "node work/smoke-player-update-logs.mjs",
                    "test:item-fire-fix-release":  "node work/smoke-item-fire-fix-release.mjs",
                    "test:release-flow":  "node work/smoke-r2-release-flow.mjs",
                    "test:release-ui-flow":  "node work/smoke-r2-release-ui-flow.mjs",
                    "test:single-instance":  "node work/smoke-single-instance.mjs",
                    "verify:local":  "node work/verify-local.mjs",
                    "check:production":  "node scripts/check-production-readiness.mjs",
                    "check:production:strict":  "node scripts/check-production-readiness.mjs --strict",
                    "preview:renderer":  "node src/previewRenderer.js",
                    "cloudflare:login":  "npx --yes wrangler login",
                    "cloudflare:deploy":  "npx --yes wrangler deploy --config cloudflare/wrangler.toml",
                    "dist:win":  "electron-builder --win nsis",
                    "dist:linux":  "electron-builder --linux AppImage deb",
                    "dist:mac":  "electron-builder --mac dmg",
                    "dist:regular:windows":  "electron-builder --config build/electron-builder.windows.cjs --win",
                    "dist:regular:macos":  "electron-builder --config build/electron-builder.macos.cjs --mac --publish never",
                    "dist:regular:ubuntu":  "electron-builder --config build/electron-builder.ubuntu.cjs --linux",
                    "pack":  "electron-builder --dir",
                    "test:launcher-proof":  "node scripts/test-launcher-proof.mjs"
                },
    "dependencies":  {
                         "adm-zip":  "^0.5.16",
                         "ssh2":  "^1.17.0",
                         "yauzl":  "^3.4.0",
                         "yazl":  "^3.3.1"
                     },
    "devDependencies":  {
                            "electron":  "^42.5.0",
                            "electron-builder":  "^26.15.3",
                            "lucide-static":  "^1.21.0"
                        },
    "build":  {
                  "appId":  "com.ahardtime.launcher",
                  "productName":  "A Hard Time Launcher",
                  "icon":  "build/icon",
                  "directories":  {
                                      "output":  "release-builds"
                                  },
                  "files":  [
                                "build/**/*",
                                "pack-fixes/**/*",
                                "desktop/**/*",
                                "src/**/*",
                                "public/**/*",
                                "cloudflare/**/*",
                                "config/**/*",
                                "server-lock-mod/build/libs/aht-version-lock-*.jar",
                                "!server-lock-mod/build/libs/*-sources.jar",
                                "server-lock-mod/README.md",
                                "package.json",
                                "README.md"
                            ],
                  "win":  {
                              "target":  "nsis"
                          },
                  "linux":  {
                                "target":  [
                                               "AppImage",
                                               "deb"
                                           ],
                                "category":  "Game"
                            },
                  "mac":  {
                              "target":  "dmg",
                              "category":  "public.app-category.games"
                          },
                  "asarUnpack":  [
                                     "server-lock-mod/build/libs/aht-version-lock-*.jar",
                                     "pack-fixes/*.jar"
                                 ],
                  "nsis":  {
                               "oneClick":  false,
                               "allowToChangeInstallationDirectory":  true,
                               "runAfterFinish":  true
                           }
              }
}
